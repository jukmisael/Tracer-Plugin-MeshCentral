<html>
<head><meta charset="utf-8"><title>{{nodeName}}</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:transparent;color:#333;padding:12px;font-size:13px}
h2{font-size:16px;margin-bottom:2px}
.sub{color:#666;font-size:12px;margin-bottom:8px}
.tab-bar{border-bottom:2px solid #ddd;margin-bottom:8px}
.tab-bar button{padding:6px 12px;border:none;background:#eee;cursor:pointer;font-size:11px;margin-bottom:-2px;border-bottom:2px solid transparent}
.tab-bar button:hover{background:#e0e0e0}
.tab-bar button.active{background:#fff;border-bottom-color:#1976D2;font-weight:600;color:#1976D2}
.pane{display:none}.pane.active{display:block}
.info{background:#e3f2fd;border:1px solid #90caf9;border-radius:6px;padding:10px;margin-bottom:8px}
.info .lbl{font-size:11px;color:#666}
.info .val{font-size:18px;font-weight:600;color:#1976D2}
table{width:100%;border-collapse:collapse;font-size:11px}
th,td{padding:4px 6px;text-align:left;border-bottom:1px solid #eee}
th{background:#fafafa;font-weight:600}
.loading{text-align:center;padding:20px;color:#999}
.ctrl{margin-bottom:6px;display:flex;gap:4px;flex-wrap:wrap}
.ctrl select,.ctrl button{font-size:11px;padding:3px 6px}
.ctrl button{background:#1976D2;color:#fff;border:none;border-radius:3px;cursor:pointer}
.badge-login{color:#4CAF50;font-weight:600}
.badge-logout{color:#F44336;font-weight:600}
.dbg{font-size:9px;color:#999;margin-top:6px;cursor:pointer}
#debug{display:none;background:#fff3cd;border:1px solid #ffeeba;padding:4px;margin-top:4px;font-size:8px;font-family:monospace;white-space:pre-wrap;max-height:120px;overflow:auto}
</style>
</head>
<body>
<h2>User Tracer</h2>
<p class="sub">{{nodeName}}</p>
<div class="tab-bar">
    <button class="active" onclick="switchTab('now')">Agora</button>
    <button onclick="switchTab('history')">Histórico</button>
</div>
<div id="pane-now" class="pane active"><div id="info" class="loading">Carregando...</div></div>
<div id="pane-history" class="pane">
    <div class="ctrl">
        <select id="fTipo2" onchange="loadHistory()"><option value="">Todos</option><option value="userLogin">Login</option><option value="userLogout">Logout</option></select>
        <button onclick="loadHistory()">Atualizar</button>
    </div>
    <div style="overflow-x:auto">
    <table><thead><tr><th>Data</th><th>Evento</th><th>Usuário</th></tr></thead>
    <tbody id="tlbody"><tr><td colspan="3" class="loading">Carregando...</td></tr></tbody></table>
    </div>
</div>
<div class="dbg" onclick="var d=document.getElementById('debug');d.style.display=d.style.display==='none'?'block':'none'">🔽 Device Debug</div>
<div id="debug">aguardando...</div>

<script>
var D=[],nodeid='{{nodeid}}',ms=(typeof parent!=='undefined'&&parent.meshserver)||window.meshserver;
function dlog(){var a=Array.prototype.slice.call(arguments);D.push(new Date().toLocaleTimeString()+' '+a.join(' '));var e=document.getElementById('debug');if(e)e.innerHTML=D.join('\n');console.log('[UTRACER-DEV]',a.join(' '));}
dlog('INIT node='+nodeid.substring(0,30)+'...');

function switchTab(n){
    document.querySelectorAll('.tab-bar button').forEach(function(b){b.classList.remove('active');});
    var btns=document.querySelectorAll('.tab-bar button');
    for(var i=0;i<btns.length;i++){if(btns[i].textContent.toLowerCase()===n)btns[i].classList.add('active');}
    document.querySelectorAll('.pane').forEach(function(p){p.classList.remove('active');});
    document.getElementById('pane-'+n).classList.add('active');
    if(n==='now')loadNow();else loadHistory();
}
function loadNow(){if(ms)ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getCurrentUsers'});}
var _tlData=[];
function loadHistory(){
    document.getElementById('tlbody').innerHTML='<tr><td colspan="3" class="loading">Carregando...</td></tr>';
    if(ms)ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getTimeline',nodeid:nodeid,limit:200});
}
function renderHistory(d){
    _tlData=d||[];
    var ft=document.getElementById('fTipo2').value;
    var filtered=_tlData.filter(function(e){return !ft||e.eventType===ft;});
    var h='';
    for(var i=0;i<filtered.length;i++){
        var e=filtered[i],dt=e.detectedAt?new Date(e.detectedAt):new Date();
        var lbl=e.eventType==='userLogin'?'<span class="badge-login">Login</span>':'<span class="badge-logout">Logout</span>';
        h+='<tr><td>'+dt.toLocaleDateString()+' '+dt.toLocaleTimeString()+'</td><td>'+lbl+'</td><td>'+(e.username||'')+'</td></tr>';
    }
    document.getElementById('tlbody').innerHTML=h||'<tr><td colspan="3" class="loading">Nenhum evento.</td></tr>';
}

if(ms&&ms.socket){
    var orig=ms.socket.onmessage;
    ms.socket.onmessage=function(event){
        try{
            var d=JSON.parse(event.data);
            if(d.action==='plugin'&&d.plugin==='usertracer'){
                if(d.method==='currentUsers'){
                    var found=null;
                    for(var i=0;i<(d.data||[]).length;i++){if(d.data[i].nodeid===nodeid){found=d.data[i];break;}}
                    var el=document.getElementById('info');
                    if(!found||!found.users||!found.users.length){el.innerHTML='<div class="loading">Nenhum usuário ativo.</div>';return;}
                    var h='';
                    found.users.forEach(function(u){
                        var usr=u.indexOf('\\')>=0?u.split('\\')[1]:u;
                        h+='<div class="info"><div class="lbl">Usuário ativo</div><div class="val">'+usr+'</div></div>';
                    });
                    el.innerHTML=h;
                } else if(d.method==='timeline'){renderHistory(d.data||[]);}
                return;
            }
        }catch(e){}
        if(typeof orig==='function')orig.call(ms.socket,event);
    };
}
document.addEventListener('DOMContentLoaded',function(){loadNow();});
</script>
</body>
</html>
