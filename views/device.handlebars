<html>
<head><meta charset="utf-8"><title>{{nodeName}}</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:transparent;color:#333;padding:12px;font-size:13px}
h2{font-size:16px;margin-bottom:4px}
.sub{color:#666;font-size:12px;margin-bottom:8px}
.info{background:#e3f2fd;border:1px solid #90caf9;border-radius:6px;padding:12px;margin-bottom:8px}
.info .lbl{font-size:11px;color:#666}
.info .val{font-size:18px;font-weight:600;color:#1976D2}
.loading{text-align:center;padding:30px;color:#999}
</style>
</head>
<body>
<h2>User Tracer</h2>
<p class="sub">{{nodeName}}</p>
<div id="info" class="loading">Carregando...</div>
<script>
var nodeid='{{nodeid}}';
var ms=(typeof parent!=='undefined'&&parent.meshserver)||window.meshserver;
function load(){
    if(ms) ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getCurrentUsers'});
}
(function(){
    var t=null;
    try{t=(typeof pluginHandler!=='undefined'&&pluginHandler.usertracer)||(parent&&parent.pluginHandler&&parent.pluginHandler.usertracer);}catch(e){}
    if(!t){setTimeout(arguments.callee,500);return;}
    t.currentUsers=function(msg){
        var d=msg&&msg.data?msg.data:[],found=null;
        for(var i=0;i<d.length;i++){if(d[i].nodeid===nodeid){found=d[i];break;}}
        var el=document.getElementById('info');
        if(!found||!found.users||!found.users.length){el.innerHTML='<div class="loading">Nenhum usuário ativo.</div>';return;}
        var h='';
        for(var j=0;j<found.users.length;j++){
            var u=found.users[j],usr=u;
            if(u.indexOf('\\')>=0) usr=u.split('\\')[1];
            else if(u.indexOf('@')>=0) usr=u.split('@')[0];
            h+='<div class="info"><div class="lbl">Usuário ativo</div><div class="val">'+usr+'</div></div>';
        }
        el.innerHTML=h;
    };
})();
document.addEventListener('DOMContentLoaded',load);
</script>
</body>
</html>
