<html>
<head><meta charset="utf-8"><title>{{nodeName}}</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:transparent;color:#333;padding:12px;font-size:13px}
h2{font-size:16px;margin-bottom:4px}
.sub{color:#666;font-size:12px;margin-bottom:8px}
.info{background:#e3f2fd;border:1px solid #90caf9;border-radius:6px;padding:12px;margin-bottom:8px}
.info .lbl{font-size:11px;color:#666}
.info .val{font-size:18px;font-weight:600;color:#1976D2}
.loading{text-align:center;padding:30px;color:#999}
.dbg{font-size:10px;color:#999;margin-top:8px;cursor:pointer}
#debug{display:none;background:#fff3cd;border:1px solid #ffeeba;padding:6px;margin-top:4px;font-size:9px;font-family:monospace;white-space:pre-wrap;max-height:150px;overflow:auto}
</style>
</head>
<body>
<h2>User Tracer</h2>
<p class="sub">{{nodeName}}</p>
<div id="info" class="loading">Carregando...</div>
<div class="dbg" onclick="var d=document.getElementById('debug');d.style.display=d.style.display==='none'?'block':'none'">🔽 Device Debug</div>
<div id="debug">aguardando...</div>
<script>
var D=[],nodeid='{{nodeid}}';
var ms=(typeof parent!=='undefined'&&parent.meshserver)||window.meshserver;
function dlog(){var a=Array.prototype.slice.call(arguments);var m=new Date().toLocaleTimeString()+' '+a.join(' ');D.push(m);var el=document.getElementById('debug');if(el)el.innerHTML=D.join('\n');console.log('[UTRACER-DEV]',a.join(' '));}
dlog('INIT node='+nodeid+' ms='+(ms?'OK':'NULL'));
function load(){
    dlog('LOAD: sending');
    document.getElementById('info').innerHTML='<div class="loading">Carregando...</div>';
    if(ms) ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getCurrentUsers'});
}
// Hook socket directly
if(ms&&ms.socket){
    var ws=ms.socket,orig=ws.onmessage;
    ws.onmessage=function(e){
        try{
            var d=JSON.parse(e.data);
            dlog('WS: action='+d.action+' plugin='+d.plugin+' method='+d.method);
            if(d&&d.action==='plugin'&&d.plugin==='usertracer'&&d.method==='currentUsers'){
                dlog('MATCH! data='+(d.data?d.data.length:0));
                var found=null;
                for(var i=0;i<(d.data||[]).length;i++){if(d.data[i].nodeid===nodeid){found=d.data[i];break;}}
                var el=document.getElementById('info');
                if(!found||!found.users||!found.users.length){el.innerHTML='<div class="loading">Nenhum usuário ativo.</div>';dlog('no user for this device');return;}
                var h='';
                for(var j=0;j<found.users.length;j++){
                    var u=found.users[j],usr=u;
                    if(u.indexOf('\\')>=0)usr=u.split('\\')[1];else if(u.indexOf('@')>=0)usr=u.split('@')[0];
                    h+='<div class="info"><div class="lbl">Usuário ativo</div><div class="val">'+usr+'</div></div>';
                }
                el.innerHTML=h;dlog('rendered: '+found.users.join(','));
                return;
            }
        }catch(ex){dlog('WS err: '+ex.message);}
        if(typeof orig==='function')orig.call(ws,e);
    };
    dlog('socket hooked');
}
document.addEventListener('DOMContentLoaded',function(){dlog('DOM ready');load();});
</script>
</body>
</html>
