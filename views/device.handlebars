<html>
<head>
<meta charset="utf-8">
<title>{{nodeName}}</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:"Trebuchet MS",Arial,Helvetica,sans-serif;
  background:transparent;
  color:#000;
  padding:10px;
  font-size:12px;
}
h2{font-size:15px;font-weight:700;color:#003366}
.sub{color:#555;font-size:11px;margin:2px 0 8px}
.tabs{display:flex;gap:0;margin-bottom:8px;border-bottom:2px solid #003366}
.tabs button{
  border:1px solid #808080;border-bottom:none;background:#606060;color:#fff;
  padding:6px 12px;cursor:pointer;font-family:inherit;font-size:11px;margin-right:2px;
  border-radius:4px 4px 0 0;
}
.tabs button.active{background:#003366;border-color:#003366;font-weight:700}
.pane{display:none}.pane.active{display:block}
.panel{background:#fff;border:1px solid #aaa;border-radius:2px;padding:10px;margin-bottom:8px}
.panel-title{background:#c0c0c0;font-size:11px;font-weight:700;padding:4px 7px;margin:-10px -10px 8px -10px;border-bottom:1px solid #aaa}
.ucard{display:flex;gap:10px;align-items:center;background:#f7f8f7;border:1px solid #bbb;border-radius:2px;padding:10px;margin-bottom:6px}
.uav{width:34px;height:34px;border-radius:2px;display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;flex-shrink:0;background:#003366}
.uname{font-weight:700;color:#000;font-size:13px}
.udev{color:#555;font-size:11px;margin-top:1px}
.ubadge{display:inline-block;margin-top:3px;font-size:10px;padding:1px 6px;border-radius:2px;background:#ddd;color:#333;font-weight:700}
.online{width:8px;height:8px;border-radius:50%;background:#2e7d32;margin-left:auto}
.toolbar{display:flex;flex-wrap:wrap;gap:5px;align-items:center;margin-bottom:6px}
.toolbar input{font-family:inherit;font-size:11px;border:1px solid #808080;background:#fff;padding:4px 6px}
.btn{font-family:inherit;font-size:11px;border:1px solid #808080;background:#f0f0f0;color:#000;padding:4px 10px;cursor:pointer;border-radius:2px}
.btn-primary{background:#003366;color:#fff;border-color:#002244}
.btn-chip{background:#ddd;border:1px solid #aaa}
.btn-chip.active{background:#003366;color:#fff;border-color:#003366;font-weight:700}
.tl-wrap{overflow:auto;border:1px solid #aaa;background:#fff}
.tl-axis{display:flex;border-bottom:1px solid #aaa;background:#e4e9e7;position:sticky;top:0;z-index:2}
.tl-axis-label{width:90px;flex-shrink:0;padding:6px 7px;font-size:9px;color:#333;font-weight:700;border-right:1px solid #aaa}
.tl-axis-track{flex:1;position:relative;height:28px;min-width:520px}
.tl-tick{position:absolute;top:0;bottom:0;border-left:1px dashed #ccc}
.tl-tick span{position:absolute;top:6px;left:3px;font-size:8px;color:#666;white-space:nowrap}
.tl-row{display:flex;min-height:40px;border-bottom:1px solid #e0e0e0}
.tl-dev{width:90px;flex-shrink:0;padding:7px;border-right:1px solid #ccc;font-size:10px;color:#003366;font-weight:700;display:flex;align-items:center;background:#fff}
.tl-track{flex:1;position:relative;min-width:520px;min-height:40px}
.sess{position:absolute;top:9px;height:20px;border-radius:2px;min-width:3px;font-size:9px;font-weight:700;color:#fff;padding:0 4px;display:flex;align-items:center;overflow:hidden;white-space:nowrap;border:1px solid rgba(0,0,0,.2);cursor:pointer}
.sess.open{border-style:dashed;border-width:2px}
.marker{position:absolute;top:8px;width:7px;height:22px;border-radius:1px;opacity:.9}
.marker.login{background:#2e7d32}.marker.logout{background:#c62828}
.empty,.loading{text-align:center;padding:24px;color:#666}
.tip{position:fixed;z-index:99;background:#003366;border:1px solid #002244;color:#fff;padding:6px 8px;border-radius:2px;font-size:10px;display:none;max-width:240px;pointer-events:none}
.dbg{margin-top:8px;font-size:10px;color:#003366;cursor:pointer;text-decoration:underline}
#debug{display:none;background:#fff8e1;border:1px solid #e0c060;color:#333;padding:5px;margin-top:4px;font-size:9px;font-family:Consolas,monospace;max-height:100px;overflow:auto;white-space:pre-wrap}
.legend{display:flex;gap:10px;font-size:10px;color:#444;margin-top:5px}
.legend i{display:inline-block;width:10px;height:10px;border-radius:1px;margin-right:3px;vertical-align:middle;border:1px solid #999}
</style>
</head>
<body>
<h2>User Tracer</h2>
<div class="sub">{{nodeName}}</div>
<div class="tabs">
  <button class="active" id="tNow" onclick="switchTab('now')">Agora</button>
  <button id="tHist" onclick="switchTab('history')">Timeline</button>
</div>

<div id="pane-now" class="pane active">
  <div class="panel">
    <div class="panel-title">Usuário ativo</div>
    <div id="info"><div class="loading">Carregando...</div></div>
  </div>
</div>

<div id="pane-history" class="pane">
  <div class="panel">
    <div class="panel-title">Período</div>
    <div class="toolbar">
      <button class="btn btn-chip" data-r="today" onclick="setRange('today',this)">Hoje</button>
      <button class="btn btn-chip active" data-r="7d" onclick="setRange('7d',this)">7 dias</button>
      <button class="btn btn-chip" data-r="30d" onclick="setRange('30d',this)">30 dias</button>
      <input type="date" id="dStart">
      <input type="date" id="dEnd">
      <button class="btn btn-primary" onclick="loadHistory()">Aplicar</button>
    </div>
    <div class="legend">
      <span><i style="background:#1565c0"></i>Sessão</span>
      <span><i style="background:#2e7d32"></i>Login</span>
      <span><i style="background:#c62828"></i>Logout</span>
    </div>
  </div>
  <div id="gantt"><div class="loading">Selecione o período.</div></div>
</div>

<div id="tip" class="tip"></div>
<div class="dbg" onclick="var d=document.getElementById('debug');d.style.display=d.style.display==='none'?'block':'none'">Debug</div>
<div id="debug">aguardando...</div>

<script>
var D=[], nodeid='{{nodeid}}', nodeName='{{nodeName}}';
var ms=(typeof parent!=='undefined'&&parent.meshserver)||window.meshserver;
var COLORS=['#003366','#1565c0','#2e7d32','#6a1b9a','#00838f','#ef6c00','#c62828','#455a64'];
function dlog(){var a=Array.prototype.slice.call(arguments);D.push(new Date().toLocaleTimeString()+' '+a.join(' '));var e=document.getElementById('debug');if(e)e.innerHTML=D.slice(-60).join('\n');}
function esc(s){return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function colorFor(k){var h=0,s=String(k||'');for(var i=0;i<s.length;i++)h=((h<<5)-h)+s.charCodeAt(i)|0;return COLORS[Math.abs(h)%COLORS.length];}
function initials(n){var p=String(n||'?').replace(/[._-]/g,' ').split(/\s+/).filter(Boolean);if(!p.length)return'?';return p.length===1?p[0].substring(0,2).toUpperCase():(p[0][0]+p[1][0]).toUpperCase();}
function splitUser(u){var p=String(u||'').split('\\');return p.length>1?{d:p[0],u:p[1]}:{d:'',u:u||''};}
function ymd(d){var x=new Date(d),m=x.getMonth()+1,day=x.getDate();return x.getFullYear()+'-'+(m<10?'0':'')+m+'-'+(day<10?'0':'')+day;}
function fmtDate(d){var x=new Date(d);return isNaN(x)?'—':x.toLocaleString();}
function fmtDur(ms){if(ms<0)ms=0;var m=Math.floor(ms/60000),h=Math.floor(m/60);m%=60;if(h>24)return Math.floor(h/24)+'d '+(h%24)+'h';if(h)return h+'h '+m+'m';return m+'m';}

function setRange(kind,btn){
  document.querySelectorAll('.btn-chip[data-r]').forEach(function(b){b.classList.remove('active');});
  if(btn)btn.classList.add('active');
  var end=new Date(),start=new Date();
  if(kind==='today')start=new Date(end.getFullYear(),end.getMonth(),end.getDate());
  else if(kind==='7d')start.setDate(end.getDate()-6);
  else if(kind==='30d')start.setDate(end.getDate()-29);
  document.getElementById('dStart').value=ymd(start);
  document.getElementById('dEnd').value=ymd(end);
}
function switchTab(n){
  document.getElementById('tNow').classList.toggle('active',n==='now');
  document.getElementById('tHist').classList.toggle('active',n==='history');
  document.getElementById('pane-now').classList.toggle('active',n==='now');
  document.getElementById('pane-history').classList.toggle('active',n==='history');
  if(n==='now')loadNow(); else loadHistory();
}
function loadNow(){if(ms)ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getCurrentUsers'});}
function loadHistory(){
  var s=document.getElementById('dStart').value,e=document.getElementById('dEnd').value;
  if(!s||!e){document.getElementById('gantt').innerHTML='<div class="empty">Selecione datas.</div>';return;}
  document.getElementById('gantt').innerHTML='<div class="loading">Carregando...</div>';
  if(ms)ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getTimeline',nodeid:nodeid,startDate:s+'T00:00:00',endDate:e+'T23:59:59.999',limit:2000});
}

function renderNow(list){
  var found=null;
  for(var i=0;i<(list||[]).length;i++){if(list[i].nodeid===nodeid){found=list[i];break;}}
  var el=document.getElementById('info');
  if(!found||!found.users||!found.users.length){el.innerHTML='<div class="empty">Nenhum usuário ativo neste dispositivo.</div>';return;}
  var h='';
  found.users.forEach(function(u){
    var s=splitUser(u),c=colorFor(u);
    h+='<div class="ucard"><div class="uav" style="background:'+c+'">'+esc(initials(s.u))+'</div>';
    h+='<div><div class="uname">'+esc(s.u)+'</div><div class="udev">'+esc(nodeName)+'</div>';
    if(s.d)h+='<span class="ubadge">'+esc(s.d)+'</span>';
    h+='</div><div class="online"></div></div>';
  });
  el.innerHTML=h;
}

function buildSessions(events,rs,re){
  var by={};
  events.slice().sort(function(a,b){return new Date(a.detectedAt)-new Date(b.detectedAt);}).forEach(function(e){
    var k=e.displayUser||e.username||'?';
    if(!by[k])by[k]={user:e.username,display:k,events:[]};
    by[k].events.push(e);
  });
  var out=[];
  Object.keys(by).forEach(function(k){
    var g=by[k],open=null;
    g.events.forEach(function(e){
      var t=new Date(e.detectedAt).getTime();
      if(e.eventType==='userLogin'){
        if(open!=null)out.push({user:g.user,display:g.display,start:open,end:t,open:false});
        open=t;
      } else if(e.eventType==='userLogout'){
        if(open!=null){out.push({user:g.user,display:g.display,start:open,end:t,open:false});open=null;}
        else out.push({user:g.user,display:g.display,start:Math.max(rs,t-30*60000),end:t,open:false});
      }
    });
    if(open!=null)out.push({user:g.user,display:g.display,start:open,end:Math.min(re,Date.now()),open:true});
  });
  return out;
}

function renderGantt(events){
  events=events||[];
  if(!events.length){document.getElementById('gantt').innerHTML='<div class="empty">Nenhum evento no período.</div>';return;}
  var rs=new Date(document.getElementById('dStart').value+'T00:00:00').getTime();
  var re=new Date(document.getElementById('dEnd').value+'T23:59:59.999').getTime();
  if(isNaN(rs)||isNaN(re)||re<=rs){rs=Infinity;re=-Infinity;events.forEach(function(e){var t=new Date(e.detectedAt).getTime();if(t<rs)rs=t;if(t>re)re=t;});if(re<=rs)re=rs+86400000;}
  var total=re-rs;
  var sessions=buildSessions(events,rs,re);
  var dayMs=86400000,hourMs=3600000,span=total/dayMs;
  var step=span<=2?hourMs*3:(span<=14?dayMs:dayMs*2);
  var ticks=[],t0=Math.ceil(rs/step)*step;
  for(var t=t0;t<=re;t+=step){
    var d=new Date(t);
    ticks.push({pct:((t-rs)/total)*100,label:step<dayMs?((d.getHours()<10?'0':'')+d.getHours()+':00'):((d.getDate()<10?'0':'')+d.getDate()+'/'+(d.getMonth()+1<10?'0':'')+(d.getMonth()+1))});
  }
  var mw=Math.max(520,Math.min(1800,Math.floor(span*80)));
  var h='<div class="tl-wrap"><div class="tl-axis"><div class="tl-axis-label">SESSÃO</div><div class="tl-axis-track" style="min-width:'+mw+'px">';
  ticks.forEach(function(tk){h+='<div class="tl-tick" style="left:'+tk.pct+'%"><span>'+esc(tk.label)+'</span></div>';});
  h+='</div></div>';

  var byUser={};
  sessions.forEach(function(s){var k=s.display||s.user||'?';if(!byUser[k])byUser[k]=[];byUser[k].push(s);});
  var users=Object.keys(byUser).sort();
  if(!users.length)users=['—'];
  users.forEach(function(u){
    h+='<div class="tl-row"><div class="tl-dev">'+esc(u)+'</div><div class="tl-track" style="min-width:'+mw+'px">';
    ticks.forEach(function(tk){h+='<div class="tl-tick" style="left:'+tk.pct+'%"></div>';});
    (byUser[u]||[]).forEach(function(s){
      var left=Math.max(0,((s.start-rs)/total)*100);
      var right=Math.min(100,((s.end-rs)/total)*100);
      if(right<=left)right=left+0.2;
      var w=Math.max(0.25,right-left),c=colorFor(s.display||s.user);
      var tip=esc(s.display)+' · '+fmtDate(s.start)+(s.open?' → agora':' → '+fmtDate(s.end))+' · '+fmtDur(s.end-s.start);
      h+='<div class="sess'+(s.open?' open':'')+'" style="left:'+left+'%;width:'+w+'%;background:'+c+'" data-tip="'+tip+'" onmouseenter="showTip(event,this)" onmouseleave="hideTip()">'+esc(s.user||'')+'</div>';
    });
    events.forEach(function(e){
      if((e.displayUser||e.username||'?')!==u && users.length>1) return;
      var tt=new Date(e.detectedAt).getTime(); if(tt<rs||tt>re)return;
      var pct=((tt-rs)/total)*100;
      h+='<div class="marker '+(e.eventType==='userLogin'?'login':'logout')+'" style="left:calc('+pct+'% - 3px)" data-tip="'+esc(e.eventType+' · '+fmtDate(tt))+'" onmouseenter="showTip(event,this)" onmouseleave="hideTip()"></div>';
    });
    h+='</div></div>';
  });
  h+='</div>';
  document.getElementById('gantt').innerHTML=h;
}

function showTip(ev,el){var tip=document.getElementById('tip');tip.textContent=el.getAttribute('data-tip')||'';tip.style.display='block';tip.style.left=(ev.clientX+10)+'px';tip.style.top=(ev.clientY+10)+'px';}
function hideTip(){document.getElementById('tip').style.display='none';}

if(ms&&ms.socket){
  var orig=ms.socket.onmessage;
  ms.socket.onmessage=function(event){
    try{
      var d=JSON.parse(event.data);
      if(d.action==='plugin'&&d.plugin==='usertracer'){
        if(d.method==='currentUsers')renderNow(d.data||[]);
        else if(d.method==='timeline')renderGantt(d.data||[]);
        return;
      }
    }catch(e){}
    if(typeof orig==='function')orig.call(ms.socket,event);
  };
}
setRange('7d', document.querySelector('.btn-chip[data-r="7d"]'));
document.addEventListener('DOMContentLoaded',function(){loadNow();});
</script>
</body>
</html>
