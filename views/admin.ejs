<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>User-Device Tracer — Admin Panel</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #f5f5f5; color: #333; padding: 20px; }
h1 { font-size: 22px; margin-bottom: 8px; }
h2 { font-size: 16px; margin: 16px 0 8px; }
.subtitle { color: #666; font-size: 13px; margin-bottom: 16px; }

/* Tabs */
.tab-bar { border-bottom: 2px solid #ddd; margin-bottom: 16px; display: flex; gap: 0; }
.tab-btn { padding: 10px 18px; border: none; background: #eee; cursor: pointer; font-size: 13px; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.2s; }
.tab-btn:hover { background: #e0e0e0; }
.tab-btn.active { background: #fff; border-bottom-color: #1976D2; font-weight: 600; color: #1976D2; }
.tab-pane { display: none; }
.tab-pane.active { display: block; }

/* Controls */
.controls { margin-bottom: 12px; display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.controls label { font-size: 12px; font-weight: 600; }
.controls input, .controls select { padding: 5px 8px; border: 1px solid #ccc; border-radius: 3px; font-size: 12px; }
.controls button { padding: 5px 12px; background: #1976D2; color: #fff; border: none; border-radius: 3px; cursor: pointer; font-size: 12px; }
.controls button:hover { background: #1565C0; }

/* Table */
table { width: 100%; border-collapse: collapse; font-size: 12px; }
th, td { padding: 6px 10px; text-align: left; border-bottom: 1px solid #eee; }
th { background: #fafafa; font-weight: 600; position: sticky; top: 0; }
tr:hover { background: #f0f7ff; }
.event-userLogin { border-left: 3px solid #4CAF50; }
.event-userLogout { border-left: 3px solid #F44336; }
.event-sessionDisconnected { border-left: 3px solid #FF9800; }
.event-sessionReconnected { border-left: 3px solid #2196F3; }

/* Cards */
.card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px; }
.card { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; }
.card h3 { font-size: 14px; margin-bottom: 6px; }
.card .stat { font-size: 11px; color: #666; }
.card .device-list { margin-top: 6px; }
.card .device-tag { display: inline-block; background: #e3f2fd; color: #1565C0; padding: 2px 6px; border-radius: 3px; font-size: 11px; margin: 2px; }

/* Timeline */
.timeline { position: relative; padding-left: 30px; }
.timeline::before { content: ''; position: absolute; left: 10px; top: 0; bottom: 0; width: 2px; background: #ddd; }
.tl-item { position: relative; margin-bottom: 12px; padding: 8px 12px; background: #fff; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 12px; }
.tl-item::before { content: ''; position: absolute; left: -24px; top: 12px; width: 10px; height: 10px; border-radius: 50%; background: #1976D2; }
.tl-item.login::before { background: #4CAF50; }
.tl-item.logout::before { background: #F44336; }
.tl-item.disconnect::before { background: #FF9800; }
.tl-item.reconnect::before { background: #2196F3; }
.tl-date { font-size: 11px; color: #666; }
.tl-user { font-weight: 600; }
.tl-device { color: #1565C0; }

/* Graph container */
#graphContainer { width: 100%; height: 500px; border: 1px solid #e0e0e0; background: #fff; border-radius: 4px; }
.graph-legend { display: flex; gap: 16px; margin-bottom: 8px; font-size: 12px; }
.graph-legend span { display: flex; align-items: center; gap: 4px; }
.graph-legend .dot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }
.dot-user { background: #4CAF50; }
.dot-device { background: #1976D2; }

/* Loading */
.loading { text-align: center; padding: 40px; color: #999; }

@media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; }
    .controls { flex-direction: column; align-items: stretch; }
}
</style>
</head>
<body>

<h1>User-Device Tracer</h1>
<p class="subtitle">Rastreio de login de usuários Windows nos dispositivos gerenciados</p>

<div class="tab-bar">
    <button class="tab-btn active" onclick="switchTab('list')">Lista</button>
    <button class="tab-btn" onclick="switchTab('users')">Por Usuário</button>
    <button class="tab-btn" onclick="switchTab('devices')">Por Dispositivo</button>
    <button class="tab-btn" onclick="switchTab('timeline')">Timeline</button>
    <button class="tab-btn" onclick="switchTab('graph')">Grafo</button>
</div>

<!-- ================================================================== -->
<!-- TAB: List -->
<!-- ================================================================== -->
<div id="tab-list" class="tab-pane active">
    <div class="controls">
        <label>Filtrar:</label>
        <select id="filterType" onchange="loadList()">
            <option value="">Todos os eventos</option>
            <option value="userLogin">Login</option>
            <option value="userLogout">Logout</option>
            <option value="sessionDisconnected">Desconectou</option>
            <option value="sessionReconnected">Reconectou</option>
        </select>
        <input type="text" id="filterUser" placeholder="Usuário..." onkeyup="loadList()">
        <input type="text" id="filterDevice" placeholder="Dispositivo..." onkeyup="loadList()">
        <button onclick="loadList()">Atualizar</button>
    </div>
    <div style="overflow-x:auto;">
        <table>
            <thead>
                <tr>
                    <th>Data/Hora</th>
                    <th>Evento</th>
                    <th>Usuário</th>
                    <th>Domínio</th>
                    <th>Dispositivo</th>
                    <th>Sessão</th>
                    <th>Detalhe</th>
                </tr>
            </thead>
            <tbody id="listBody">
                <tr><td colspan="7" class="loading">Carregando...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ================================================================== -->
<!-- TAB: Per-User -->
<!-- ================================================================== -->
<div id="tab-users" class="tab-pane">
    <div class="controls">
        <input type="text" id="filterUserCard" placeholder="Filtrar usuário..." onkeyup="loadUsers()">
    </div>
    <div id="usersGrid" class="card-grid"></div>
</div>

<!-- ================================================================== -->
<!-- TAB: Per-Device -->
<!-- ================================================================== -->
<div id="tab-devices" class="tab-pane">
    <div class="controls">
        <input type="text" id="filterDeviceCard" placeholder="Filtrar dispositivo..." onkeyup="loadDevices()">
    </div>
    <div id="devicesGrid" class="card-grid"></div>
</div>

<!-- ================================================================== -->
<!-- TAB: Timeline -->
<!-- ================================================================== -->
<div id="tab-timeline" class="tab-pane">
    <div class="controls">
        <button onclick="loadTimeline()">Atualizar</button>
    </div>
    <div id="timelineContainer" class="timeline"></div>
</div>

<!-- ================================================================== -->
<!-- TAB: Graph -->
<!-- ================================================================== -->
<div id="tab-graph" class="tab-pane">
    <div class="graph-legend">
        <span><span class="dot dot-user"></span> Usuário</span>
        <span><span class="dot dot-device"></span> Dispositivo</span>
    </div>
    <div id="graphContainer"></div>
</div>

<!-- ================================================================== -->
<!-- Scripts -->
<!-- ================================================================== -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/vis-network/9.1.9/vis-network.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/vis-network/9.1.9/dist/vis-network.min.css">

<script>
// -----------------------------------------------------------------------
// WebSocket setup using MeshCentral's built-in messaging
// -----------------------------------------------------------------------
var ws = null;
var pendingCallbacks = {};
var callId = 0;

function connectWS() {
    // Use MeshCentral's pluginHandler messaging if available
    if (typeof pluginHandler !== 'undefined' && pluginHandler.usertracer) {
        return; // frontend exports handle it
    }
}

function sendPluginCommand(action, payload) {
    try {
        var pkt = JSON.stringify({
            action: 'plugin',
            plugin: 'usertracer',
            pluginaction: action,
            nodeid: payload.nodeid || '',
            limit: payload.limit || 500,
            username: payload.username || '',
            eventType: payload.eventType || ''
        });
        if (typeof pnetMsg !== 'undefined') {
            pnetMsg(pkt);
        } else if (typeof parent !== 'undefined' && parent.pnetMsg) {
            parent.pnetMsg(pkt);
        }
    } catch(e) {}
}

// Listen for responses via MeshCentral's plugin message system
if (typeof pluginHandler !== 'undefined' && parent !== window) {
    // We're in an iframe - responses arrive via pluginHandler exports
    var originalHandler = parent.pluginHandler;
    if (originalHandler && originalHandler.usertracer) {
        // Already set up by the main window
    }
}

// -----------------------------------------------------------------------
// Tab switching
// -----------------------------------------------------------------------
function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });
    document.querySelector('.tab-btn[onclick*="' + name + '"]').classList.add('active');
    document.getElementById('tab-' + name).classList.add('active');

    switch (name) {
        case 'list': loadList(); break;
        case 'users': loadUsers(); break;
        case 'devices': loadDevices(); break;
        case 'timeline': loadTimeline(); break;
        case 'graph': loadGraph(); break;
    }
}

// -----------------------------------------------------------------------
// Tab: List
// -----------------------------------------------------------------------
function loadList() {
    var tbody = document.getElementById('listBody');
    tbody.innerHTML = '<tr><td colspan="7" class="loading">Carregando...</td></tr>';

    var filterUser = document.getElementById('filterUser').value.trim().toLowerCase();
    var filterDevice = document.getElementById('filterDevice').value.trim().toLowerCase();
    var filterType = document.getElementById('filterType').value;

    sendPluginCommand('getAllEvents', {
        limit: 500,
        username: filterUser,
        // Server-side filtering is basic; we do client-side for the rest
    });

    // Store filter for use in response
    window._listFilter = { user: filterUser, device: filterDevice, type: filterType };
}

function renderList(data) {
    var tbody = document.getElementById('listBody');
    var filter = window._listFilter || {};

    if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="loading">Nenhum evento encontrado.</td></tr>';
        return;
    }

    var html = '';
    for (var i = 0; i < data.length; i++) {
        var e = data[i];

        // Client-side filtering
        if (filter.type && e.eventType !== filter.type) continue;
        if (filter.user) {
            var un = (e.username || '').toLowerCase();
            if (un.indexOf(filter.user) === -1) continue;
        }
        if (filter.device) {
            var dn = (e.nodeName || e.nodeid || '').toLowerCase();
            if (dn.indexOf(filter.device) === -1) continue;
        }

        var eventLabels = {
            userLogin: 'Login',
            userLogout: 'Logout',
            sessionDisconnected: 'Desconectou',
            sessionReconnected: 'Reconectou'
        };
        var d = new Date(e.detectedAt);
        var dateStr = d.toLocaleDateString() + ' ' + d.toLocaleTimeString();

        html += '<tr class="event-' + e.eventType + '">';
        html += '<td>' + dateStr + '</td>';
        html += '<td>' + (eventLabels[e.eventType] || e.eventType) + '</td>';
        html += '<td>' + (e.username || '') + '</td>';
        html += '<td>' + (e.domain || '') + '</td>';
        html += '<td>' + (e.nodeName || e.nodeid || '') + '</td>';
        html += '<td>' + (e.sessionName || '') + '</td>';
        html += '<td>' + (e.state || e.currentState || e.previousState || '') + '</td>';
        html += '</tr>';
    }

    if (!html) {
        tbody.innerHTML = '<tr><td colspan="7" class="loading">Nenhum evento corresponde ao filtro.</td></tr>';
    } else {
        tbody.innerHTML = html;
    }
}

// -----------------------------------------------------------------------
// Tab: Per-User
// -----------------------------------------------------------------------
function loadUsers() {
    document.getElementById('usersGrid').innerHTML = '<div class="loading">Carregando...</div>';
    sendPluginCommand('getEventsByUser', {});
}

function renderUsers(data) {
    var grid = document.getElementById('usersGrid');
    var filter = (document.getElementById('filterUserCard').value || '').trim().toLowerCase();

    if (!data) {
        grid.innerHTML = '<div class="loading">Nenhum dado.</div>';
        return;
    }

    var keys = Object.keys(data).sort();
    var html = '';
    var count = 0;
    for (var k = 0; k < keys.length; k++) {
        var u = data[keys[k]];
        var label = u.domain ? u.domain + '\\' + u.username : u.username;
        if (filter && label.toLowerCase().indexOf(filter) === -1) continue;

        var deviceCount = Object.keys(u.devices).length;
        var deviceHtml = '';
        var deviceNames = Object.keys(u.devices).sort();
        for (var d = 0; d < deviceNames.length; d++) {
            deviceHtml += '<span class="device-tag">' + deviceNames[d] + ' (' + u.devices[deviceNames[d]].count + ')</span>';
        }

        count++;
        html += '<div class="card">';
        html += '<h3>' + label + '</h3>';
        html += '<div class="stat">Eventos: ' + u.totalEvents + ' | Dispositivos: ' + deviceCount + '</div>';
        html += '<div class="stat">Primeiro: ' + (u.firstSeen ? new Date(u.firstSeen).toLocaleString() : '-') + '</div>';
        html += '<div class="stat">Último: ' + (u.lastSeen ? new Date(u.lastSeen).toLocaleString() : '-') + '</div>';
        html += '<div class="device-list">' + deviceHtml + '</div>';
        html += '</div>';
    }

    if (count === 0) {
        grid.innerHTML = '<div class="loading">Nenhum usuário encontrado.</div>';
    } else {
        grid.innerHTML = html;
    }
}

// -----------------------------------------------------------------------
// Tab: Per-Device
// -----------------------------------------------------------------------
function loadDevices() {
    document.getElementById('devicesGrid').innerHTML = '<div class="loading">Carregando...</div>';
    sendPluginCommand('getEventsByDevice', {});
}

function renderDevices(data) {
    var grid = document.getElementById('devicesGrid');
    var filter = (document.getElementById('filterDeviceCard').value || '').trim().toLowerCase();

    if (!data) {
        grid.innerHTML = '<div class="loading">Nenhum dado.</div>';
        return;
    }

    var keys = Object.keys(data).sort();
    var html = '';
    var count = 0;
    for (var k = 0; k < keys.length; k++) {
        var d = data[keys[k]];
        if (filter && d.nodeName.toLowerCase().indexOf(filter) === -1) continue;

        var userCount = Object.keys(d.users).length;
        var userHtml = '';
        var userNames = Object.keys(d.users).sort();
        for (var u = 0; u < userNames.length; u++) {
            userHtml += '<span class="device-tag">' + userNames[u] + ' (' + d.users[userNames[u]].count + ')</span>';
        }

        count++;
        html += '<div class="card">';
        html += '<h3>' + d.nodeName + '</h3>';
        html += '<div class="stat">Eventos: ' + d.totalEvents + ' | Usuários distintos: ' + userCount + '</div>';
        html += '<div class="stat">Último evento: ' + (d.lastSeen ? new Date(d.lastSeen).toLocaleString() : '-') + '</div>';
        html += '<div class="device-list">' + userHtml + '</div>';
        html += '</div>';
    }

    if (count === 0) {
        grid.innerHTML = '<div class="loading">Nenhum dispositivo encontrado.</div>';
    } else {
        grid.innerHTML = html;
    }
}

// -----------------------------------------------------------------------
// Tab: Timeline
// -----------------------------------------------------------------------
function loadTimeline() {
    var container = document.getElementById('timelineContainer');
    container.innerHTML = '<div class="loading">Carregando...</div>';
    sendPluginCommand('getTimeline', { limit: 300 });
}

function renderTimeline(data) {
    var container = document.getElementById('timelineContainer');

    if (!data || data.length === 0) {
        container.innerHTML = '<div class="loading">Nenhum evento registrado.</div>';
        return;
    }

    var html = '';
    for (var i = 0; i < data.length; i++) {
        var e = data[i];
        var d = new Date(e.date);
        var dateStr = d.toLocaleDateString() + ' ' + d.toLocaleTimeString();

        var cssClass = 'tl-item';
        if (e.type.indexOf('Login') !== -1) cssClass += ' login';
        else if (e.type.indexOf('Logout') !== -1) cssClass += ' logout';
        else if (e.type.indexOf('Disconnect') !== -1) cssClass += ' disconnect';
        else if (e.type.indexOf('Reconnect') !== -1) cssClass += ' reconnect';

        html += '<div class="' + cssClass + '">';
        html += '<div class="tl-date">' + dateStr + '</div>';
        html += '<span class="tl-user">' + e.user + '</span>';
        html += ' → <span class="tl-device">' + e.device + '</span>';
        html += ' <span style="color:#666">(' + e.detail + ')</span>';
        if (e.session) html += ' <span style="color:#999;font-size:11px">[' + e.session + ']</span>';
        html += '</div>';
    }

    container.innerHTML = html;
}

// -----------------------------------------------------------------------
// Tab: Graph
// -----------------------------------------------------------------------
function loadGraph() {
    sendPluginCommand('getGraphData', {});
}

function renderGraph(data) {
    var container = document.getElementById('graphContainer');
    if (!data || !data.nodes || data.nodes.length === 0) {
        container.innerHTML = '<div class="loading">Dados insuficientes para gerar o grafo.</div>';
        return;
    }

    var nodes = new vis.DataSet(data.nodes.map(function(n) {
        return {
            id: n.id,
            label: n.label,
            title: n.title,
            shape: n.type === 'user' ? 'dot' : 'square',
            color: n.type === 'user' ? '#4CAF50' : '#1976D2',
            size: n.type === 'user' ? 20 : 25,
            borderWidth: 2,
            font: { size: 11, face: 'Segoe UI' }
        };
    }));

    var edges = new vis.DataSet(data.edges.map(function(e) {
        var opacity = Math.min(1, 0.2 + (e.value / 10));
        var width = Math.min(8, 1 + e.value * 0.5);
        return {
            from: e.from,
            to: e.to,
            value: e.value,
            width: width,
            color: { color: 'rgba(76,175,80,' + opacity + ')', highlight: '#1976D2' },
            smooth: { type: 'curvedCW', roundness: 0.1 },
            title: e.title
        };
    }));

    var options = {
        layout: {
            improvedLayout: true,
            hierarchical: { enabled: false }
        },
        physics: {
            solver: 'forceAtlas2Based',
            forceAtlas2Based: {
                gravitationalConstant: -40,
                centralGravity: 0.005,
                springLength: 200,
                springConstant: 0.02,
                damping: 0.4
            },
            stabilization: { iterations: 200 }
        },
        interaction: {
            hover: true,
            tooltipDelay: 200,
            navigationButtons: true,
            keyboard: true
        },
        edges: {
            arrows: { to: { enabled: false } }
        }
    };

    new vis.Network(container, { nodes: nodes, edges: edges }, options);
}

// -----------------------------------------------------------------------
// Message handler — register on parent's pluginHandler so MeshCentral's
// WebSocket message router delivers responses directly to us.
// -----------------------------------------------------------------------
function handlePluginMessage(method, data) {
    switch (method) {
        case 'allEvents':
            renderList(data);
            break;
        case 'eventsByUser':
            renderUsers(data);
            break;
        case 'eventsByDevice':
            renderDevices(data);
            break;
        case 'timeline':
            renderTimeline(data);
            break;
        case 'graphData':
            renderGraph(data);
            break;
    }
}

// Register handlers on the parent's pluginHandler so MeshCentral's WebSocket
// router calls them directly: pluginHandler.usertracer[method](msg)
(function registerHandlers() {
    var target = null;
    try {
        if (typeof pluginHandler !== 'undefined' && pluginHandler.usertracer) {
            target = pluginHandler.usertracer;
        } else if (typeof parent !== 'undefined' && parent.pluginHandler && parent.pluginHandler.usertracer) {
            target = parent.pluginHandler.usertracer;
        }
    } catch(e) {
        // Cross-origin iframe — fallback: poll for target
    }

    if (!target) {
        // Retry after a short delay (iframe may not be fully initialized)
        setTimeout(registerHandlers, 500);
        return;
    }

    var methods = ['allEvents', 'eventsByUser', 'eventsByDevice', 'timeline', 'graphData', 'deviceEvents'];
    for (var i = 0; i < methods.length; i++) {
        (function(m) {
            target[m] = function(msg) {
                var data = (msg && msg.data !== undefined) ? msg.data : msg;
                handlePluginMessage(m, data);
            };
        })(methods[i]);
    }
})();

// Auto-load first tab on page ready
document.addEventListener('DOMContentLoaded', function() {
    loadList();
});
</script>

</body>
</html>
