<html>
<head><meta charset="utf-8"><title>User Tracer</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:#f5f5f5;color:#333;padding:20px;font-size:13px}
h1{font-size:20px;margin-bottom:4px}
.sub{color:#666;font-size:12px;margin-bottom:16px}
table{width:100%;border-collapse:collapse;font-size:12px}
th,td{padding:6px 10px;text-align:left;border-bottom:1px solid #eee}
th{background:#fafafa;font-weight:600}
tr:hover{background:#f0f7ff}
.loading{text-align:center;padding:40px;color:#999}
</style>
</head>
<body>
<h1>User Tracer</h1>
<p class="sub">Usuários ativos nos dispositivos neste momento</p>
<div id="debug" style="display:none;background:#fff3cd;border:1px solid #ffeeba;padding:8px;margin-bottom:12px;font-size:11px;font-family:monospace;white-space:pre-wrap;max-height:200px;overflow:auto"></div>
<div style="overflow-x:auto">
<table><thead><tr><th>Dispositivo</th><th>Usuário</th><th>Domínio</th></tr></thead>
<tbody id="tbody"><tr><td colspan="3" class="loading">Carregando...</td></tr></tbody></table>
</div>
<script>
var D = [];
function dlog() {
    var args = Array.prototype.slice.call(arguments);
    var msg = new Date().toLocaleTimeString() + ' ' + args.join(' ');
    D.push(msg);
    console.log('[USERTRACER]', args.join(' '));
    var el = document.getElementById('debug');
    if (el) { el.innerHTML = D.join('\n'); el.style.display = 'block'; }
}

dlog('INIT: loaded');
var ms = (typeof parent !== 'undefined' && parent.meshserver) || (window.meshserver || null);
dlog('INIT: meshserver=' + (ms ? 'available' : 'NULL') + ' socket=' + (ms && ms.socket ? 'present' : 'null'));

function renderTable(d) {
    dlog('RENDER: ' + d.length + ' devices, sample=' + (d[0] ? JSON.stringify(d[0]).substring(0,100) : ''));
    var h = '';
    for (var i = 0; i < d.length; i++) {
        var users = d[i].users || [];
        for (var j = 0; j < users.length; j++) {
            var u = users[j], dom = '', usr = u;
            if (u.indexOf('\\') >= 0) { dom = u.split('\\')[0]; usr = u.split('\\')[1]; }
            else if (u.indexOf('@') >= 0) { dom = u.split('@')[1]; usr = u.split('@')[0]; }
            h += '<tr><td>' + d[i].nodeName + '</td><td>' + usr + '</td><td>' + dom + '</td></tr>';
        }
    }
    document.getElementById('tbody').innerHTML = h || '<tr><td colspan="3" class="loading">Nenhum usuário ativo.</td></tr>';
    dlog('RENDER: done');
}

// Hook into the REAL WebSocket onmessage (BEFORE MeshCentral processes it)
if (ms && ms.socket) {
    var ws = ms.socket;
    var origOnMsg = ws.onmessage;
    ws.onmessage = function(event) {
        try {
            var d = JSON.parse(event.data);
            dlog('SOCKET: raw msg action=' + d.action + ' plugin=' + d.plugin + ' method=' + d.method);
            if (d && d.action === 'plugin' && d.plugin === 'usertracer' && d.method === 'currentUsers') {
                dlog('SOCKET: MATCH! data=' + (Array.isArray(d.data) ? 'array[' + d.data.length + ']' : typeof d.data));
                renderTable(d.data || []);
                return;
            }
        } catch(e) { dlog('SOCKET: parse error: ' + e.message); }
        if (typeof origOnMsg === 'function') origOnMsg.call(ws, event);
    };
    dlog('SOCKET: listener installed');
} else {
    dlog('SOCKET: no socket available, fallback to pluginHandler');
    (function register() {
        var t = null;
        try {
            if (typeof pluginHandler !== 'undefined' && pluginHandler.usertracer) t = pluginHandler.usertracer;
            else if (parent && parent.pluginHandler && parent.pluginHandler.usertracer) t = parent.pluginHandler.usertracer;
        } catch(e) {}
        if (!t) { setTimeout(register, 500); return; }
        t.currentUsers = function(msg) {
            dlog('PH: handler called, keys=' + (msg ? Object.keys(msg).join(',') : 'null'));
            if (msg && msg.State !== undefined) { dlog('PH: IGNORED - meshserver obj'); return; }
            var d = (msg && msg.data) ? msg.data : (Array.isArray(msg) ? msg : []);
            if (d.length > 0) renderTable(d);
        };
        dlog('PH: registered');
    })();
}

function load() {
    dlog('LOAD: sending getCurrentUsers');
    document.getElementById('tbody').innerHTML = '<tr><td colspan="3" class="loading">Carregando...</td></tr>';
    if (ms) { ms.send({action:'plugin', plugin:'usertracer', pluginaction:'getCurrentUsers'}); dlog('LOAD: sent'); }
}

document.addEventListener('DOMContentLoaded', load);
dlog('INIT: complete');
</script>
</body>
</html>
