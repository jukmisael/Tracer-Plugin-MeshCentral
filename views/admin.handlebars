<html>
<head><meta charset="utf-8"><title>User Tracer</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:#f5f5f5;color:#333;padding:20px;font-size:13px}
h1{font-size:20px;margin-bottom:4px}
.sub{color:#666;font-size:12px;margin-bottom:16px}
table{width:100%;border-collapse:collapse;font-size:12px}
th,td{padding:6px 10px;text-align:left;border-bottom:1px solid #eee}
th{background:#fafafa;font-weight:600}
tr:hover{background:#f0f7ff}
.loading{text-align:center;padding:40px;color:#999}
#dbgToggle{cursor:pointer;font-size:11px;color:#1976D2;margin-bottom:4px;user-select:none}
#dbgToggle:hover{text-decoration:underline}
#debug{display:none;background:#fff3cd;border:1px solid #ffeeba;padding:8px;margin-bottom:12px;font-size:10px;font-family:monospace;white-space:pre-wrap;max-height:300px;overflow:auto}
#dbgCount{color:#999;font-size:10px;margin-left:8px}
</style>
</head>
<body>
<h1>User Tracer</h1>
<p class="sub">Usuários ativos nos dispositivos neste momento</p>
<div id="dbgToggle" onclick="toggleDebug()">🔽 Debug <span id="dbgCount">0</span></div>
<div id="debug">aguardando eventos...</div>
<div style="overflow-x:auto">
<table><thead><tr><th>Dispositivo</th><th>Usuário</th><th>Domínio</th></tr></thead>
<tbody id="tbody"><tr><td colspan="3" class="loading">Carregando...</td></tr></tbody></table>
</div>
<script>
// === FULL WS DEBUG — COLLAPSIBLE ===
var D = [];
var dbgVisible = false;

function dlog() {
    var args = Array.prototype.slice.call(arguments);
    var msg = new Date().toLocaleTimeString() + ' ' + args.join(' ');
    D.push(msg);
    console.log('[UTRACER]', args.join(' '));
    var el = document.getElementById('debug');
    var ct = document.getElementById('dbgCount');
    if (el) { el.innerHTML = D.join('\n'); el.scrollTop = el.scrollHeight; }
    if (ct) ct.textContent = D.length;
}
function toggleDebug() {
    var el = document.getElementById('debug');
    var tg = document.getElementById('dbgToggle');
    dbgVisible = !dbgVisible;
    if (el) el.style.display = dbgVisible ? 'block' : 'none';
    if (tg) tg.innerHTML = (dbgVisible ? '🔼' : '🔽') + ' Debug <span id="dbgCount">' + D.length + '</span>';
}

dlog('=== INIT START ===');
dlog('INIT: url=' + location.href);
dlog('INIT: parent=' + (typeof parent));
dlog('INIT: window.meshserver=' + (typeof window.meshserver));

var ms = (typeof parent !== 'undefined' && parent.meshserver) ? parent.meshserver : (window.meshserver || null);
dlog('INIT: ms=' + (ms ? 'OBJ' : 'NULL'));
if (ms) {
    dlog('INIT: ms.type=' + typeof ms);
    dlog('INIT: ms.keys=' + Object.keys(ms).sort().join(','));
    dlog('INIT: ms.socket=' + (ms.socket ? 'OBJ' : 'NULL'));
    dlog('INIT: ms.socket.readyState=' + (ms.socket ? ms.socket.readyState : 'N/A'));
    dlog('INIT: ms.socket.url=' + (ms.socket ? ms.socket.url : 'N/A'));
    dlog('INIT: ms.socket.onmessage=' + (ms.socket && ms.socket.onmessage ? 'DEFINED' : 'NULL'));
    dlog('INIT: ms.State=' + ms.State);
    dlog('INIT: ms.connectstate=' + ms.connectstate);
}

function renderTable(d) {
    dlog('RENDER: rendering ' + d.length + ' devices');
    var h = '';
    for (var i = 0; i < d.length; i++) {
        var users = d[i].users || [];
        for (var j = 0; j < users.length; j++) {
            var u = users[j], dom = '', usr = u;
            if (u.indexOf('\\') >= 0) { dom = u.split('\\')[0]; usr = u.split('\\')[1]; }
            else if (u.indexOf('@') >= 0) { dom = u.split('@')[1]; usr = u.split('@')[0]; }
            h += '<tr><td>' + d[i].nodeName + '</td><td>' + usr + '</td><td>' + dom + '</td></tr>';
        }
    }
    document.getElementById('tbody').innerHTML = h || '<tr><td colspan="3" class="loading">Nenhum usuário ativo.</td></tr>';
    dlog('RENDER: done, html=' + (h.length > 0 ? h.substring(0,100) : 'empty'));
}

// === INTERCEPT ALL WS ACTIVITY ===
if (ms) {
    // 1. Intercept ms.send() — every outgoing message
    dlog('WS: wrapping ms.send...');
    var _origSend = ms.send;
    if (typeof _origSend === 'function') {
        ms.send = function(pkt) {
            dlog('SEND: action=' + pkt.action + ' plugin=' + pkt.plugin + ' pluginaction=' + pkt.pluginaction + ' full=' + JSON.stringify(pkt).substring(0,300));
            return _origSend.call(ms, pkt);
        };
        dlog('WS: ms.send wrapped');
    } else {
        dlog('WS: ms.send is NOT a function, type=' + typeof _origSend);
    }

    // 2. Intercept ALL raw WebSocket activity
    if (ms.socket) {
        var ws = ms.socket;
        dlog('WS: socket.readyState=' + ws.readyState + ' buffered=' + ws.bufferedAmount);
        
        var events = ['open', 'close', 'error', 'message'];
        events.forEach(function(evtName) {
            var origHandler = ws['on' + evtName];
            ws['on' + evtName] = function(event) {
                if (evtName === 'message') {
                    try {
                        var raw = (typeof event.data === 'string') ? event.data : '[non-string]';
                        dlog('WS MSG: len=' + raw.length + ' raw=' + raw.substring(0,600));
                        try {
                            var parsed = JSON.parse(raw);
                            dlog('WS PARSE: action=' + parsed.action + ' plugin=' + parsed.plugin + ' method=' + parsed.method);
                            if (parsed.action === 'plugin' && parsed.plugin === 'usertracer') {
                                dlog('WS >>> USERTRACER MATCH <<<');
                                if (parsed.method === 'currentUsers') {
                                    renderTable(parsed.data || []);
                                    return;
                                }
                            }
                        } catch(ep) {
                            dlog('WS PARSE FAIL: ' + ep.message.substring(0,100));
                        }
                    } catch(e) {
                        dlog('WS RAW FAIL: ' + e.message);
                    }
                } else {
                    dlog('WS EVT: ' + evtName + (event.code !== undefined ? ' code=' + event.code : '') + (event.reason ? ' reason=' + event.reason : ''));
                }
                if (typeof origHandler === 'function') origHandler.call(ws, event);
            };
        });
        dlog('WS: all events hooked');
    } else {
        dlog('WS: NO SOCKET, fallback to ms.onMessage');
        var _origOnMsg = ms.onMessage;
        ms.onMessage = function(e) {
            try {
                var d = (typeof e === 'string') ? JSON.parse(e) : (e.data ? JSON.parse(e.data) : e);
                dlog('MS.ONMSG: action=' + d.action + ' plugin=' + d.plugin);
                if (d.action === 'plugin' && d.plugin === 'usertracer' && d.method === 'currentUsers') {
                    renderTable(d.data || []); return;
                }
            } catch(ex) { dlog('MS.ONMSG error: ' + ex.message); }
            if (typeof _origOnMsg === 'function') _origOnMsg(e);
        };
        dlog('WS: ms.onMessage installed');
    }
} else {
    dlog('FATAL: no meshserver');
}

function load() {
    dlog('LOAD: sending getCurrentUsers');
    document.getElementById('tbody').innerHTML = '<tr><td colspan="3" class="loading">Carregando...</td></tr>';
    if (ms) { ms.send({action:'plugin', plugin:'usertracer', pluginaction:'getCurrentUsers'}); dlog('LOAD: sent'); }
}

document.addEventListener('DOMContentLoaded', function() { dlog('DOM: ready'); load(); });
dlog('=== INIT END ===');
</script>
</body>
</html>
