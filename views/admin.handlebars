<html>
<head><meta charset="utf-8"><title>User Tracer</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:#f5f5f5;color:#333;padding:20px;font-size:13px}
h1{font-size:20px;margin-bottom:4px}
.sub{color:#666;font-size:12px;margin-bottom:16px}
table{width:100%;border-collapse:collapse;font-size:12px}
th,td{padding:6px 10px;text-align:left;border-bottom:1px solid #eee}
th{background:#fafafa;font-weight:600}
tr:hover{background:#f0f7ff}
.loading{text-align:center;padding:40px;color:#999}
</style>
</head>
<body>
<h1>User Tracer</h1>
<p class="sub">Usuários ativos nos dispositivos neste momento</p>
<div style="overflow-x:auto">
<table><thead><tr><th>Dispositivo</th><th>Usuário</th><th>Domínio</th></tr></thead>
<tbody id="tbody"><tr><td colspan="3" class="loading">Carregando...</td></tr></tbody></table>
</div>
<script>
var ms=(typeof parent!=='undefined'&&parent.meshserver)||window.meshserver;
function load(){
    document.getElementById('tbody').innerHTML='<tr><td colspan="3" class="loading">Carregando...</td></tr>';
    if(ms) ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getCurrentUsers'});
}
(function register(){
    var t=null;
    try{t=(typeof pluginHandler!=='undefined'&&pluginHandler.usertracer)||(parent&&parent.pluginHandler&&parent.pluginHandler.usertracer);}catch(e){}
    if(!t){setTimeout(register,500);return;}
    t.currentUsers=function(msg){
        // msg can be the full {action,plugin,method,data:[...]} or just the data array
        var d = (msg && msg.data) ? msg.data : (Array.isArray(msg) ? msg : []);
        var h='';
        for(var i=0;i<d.length;i++){
            var users=d[i].users||[];
            for(var j=0;j<users.length;j++){
                var u=users[j],dom='',usr=u;
                if(u.indexOf('\\')>=0){dom=u.split('\\')[0];usr=u.split('\\')[1];}
                else if(u.indexOf('@')>=0){dom=u.split('@')[1];usr=u.split('@')[0];}
                h+='<tr><td>'+d[i].nodeName+'</td><td>'+usr+'</td><td>'+dom+'</td></tr>';
            }
        }
        document.getElementById('tbody').innerHTML=h||'<tr><td colspan="3" class="loading">Nenhum usuário ativo.</td></tr>';
    };
})();
document.addEventListener('DOMContentLoaded',load);
</script>
</body>
</html>
