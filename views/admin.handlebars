<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>User-Device Tracer — Admin Panel</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #f5f5f5; color: #333; padding: 20px; }
h1 { font-size: 22px; margin-bottom: 8px; }
h2 { font-size: 16px; margin: 16px 0 8px; }
.subtitle { color: #666; font-size: 13px; margin-bottom: 16px; }
.tab-bar { border-bottom: 2px solid #ddd; margin-bottom: 16px; display: flex; gap: 0; }
.tab-btn { padding: 10px 18px; border: none; background: #eee; cursor: pointer; font-size: 13px; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.2s; }
.tab-btn:hover { background: #e0e0e0; }
.tab-btn.active { background: #fff; border-bottom-color: #1976D2; font-weight: 600; color: #1976D2; }
.tab-pane { display: none; }
.tab-pane.active { display: block; }
.controls { margin-bottom: 12px; display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.controls label { font-size: 12px; font-weight: 600; }
.controls input, .controls select { padding: 5px 8px; border: 1px solid #ccc; border-radius: 3px; font-size: 12px; }
.controls button { padding: 5px 12px; background: #1976D2; color: #fff; border: none; border-radius: 3px; cursor: pointer; font-size: 12px; }
.controls button:hover { background: #1565C0; }
table { width: 100%; border-collapse: collapse; font-size: 12px; }
th, td { padding: 6px 10px; text-align: left; border-bottom: 1px solid #eee; }
th { background: #fafafa; font-weight: 600; position: sticky; top: 0; }
tr:hover { background: #f0f7ff; }
.event-userLogin { border-left: 3px solid #4CAF50; }
.event-userLogout { border-left: 3px solid #F44336; }
.event-sessionDisconnected { border-left: 3px solid #FF9800; }
.event-sessionReconnected { border-left: 3px solid #2196F3; }
.card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px; }
.card { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; padding: 12px; }
.card h3 { font-size: 14px; margin-bottom: 6px; }
.card .stat { font-size: 11px; color: #666; }
.card .device-list { margin-top: 6px; }
.card .device-tag { display: inline-block; background: #e3f2fd; color: #1565C0; padding: 2px 6px; border-radius: 3px; font-size: 11px; margin: 2px; }
.timeline { position: relative; padding-left: 30px; }
.timeline::before { content: ''; position: absolute; left: 10px; top: 0; bottom: 0; width: 2px; background: #ddd; }
.tl-item { position: relative; margin-bottom: 12px; padding: 8px 12px; background: #fff; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 12px; }
.tl-item::before { content: ''; position: absolute; left: -24px; top: 12px; width: 10px; height: 10px; border-radius: 50%; background: #1976D2; }
.tl-item.login::before { background: #4CAF50; }
.tl-item.logout::before { background: #F44336; }
.tl-item.disconnect::before { background: #FF9800; }
.tl-item.reconnect::before { background: #2196F3; }
.tl-date { font-size: 11px; color: #666; }
.tl-user { font-weight: 600; }
.tl-device { color: #1565C0; }
.loading { text-align: center; padding: 40px; color: #999; }
@media (max-width: 768px) { .card-grid { grid-template-columns: 1fr; } .controls { flex-direction: column; align-items: stretch; } }
</style>
</head>
<body>

<h1>User-Device Tracer</h1>
<p class="subtitle">Rastreio de login de usuários Windows nos dispositivos gerenciados</p>

<div class="tab-bar">
    <button class="tab-btn active" onclick="switchTab('list')">Lista</button>
    <button class="tab-btn" onclick="switchTab('users')">Por Usuário</button>
    <button class="tab-btn" onclick="switchTab('devices')">Por Dispositivo</button>
    <button class="tab-btn" onclick="switchTab('timeline')">Timeline</button>
    <button class="tab-btn" onclick="switchTab('graph')">Grafo</button>
</div>

<div id="tab-list" class="tab-pane active">
    <div class="controls">
        <label>Filtrar:</label>
        <select id="filterType" onchange="loadList()">
            <option value="">Todos os eventos</option>
            <option value="userLogin">Login</option>
            <option value="userLogout">Logout</option>
            <option value="sessionDisconnected">Desconectou</option>
            <option value="sessionReconnected">Reconectou</option>
        </select>
        <input type="text" id="filterUser" placeholder="Usuário..." onkeyup="loadList()">
        <input type="text" id="filterDevice" placeholder="Dispositivo..." onkeyup="loadList()">
        <button onclick="loadList()">Atualizar</button>
    </div>
    <div style="overflow-x:auto;">
        <table>
            <thead><tr>
                <th>Data/Hora</th><th>Evento</th><th>Usuário</th><th>Domínio</th><th>Dispositivo</th><th>Sessão</th><th>Detalhe</th>
            </tr></thead>
            <tbody id="listBody">
                <tr><td colspan="7" class="loading">Carregando...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div id="tab-users" class="tab-pane">
    <div class="controls">
        <input type="text" id="filterUserCard" placeholder="Filtrar usuário..." onkeyup="loadUsers()">
    </div>
    <div id="usersGrid" class="card-grid"></div>
</div>

<div id="tab-devices" class="tab-pane">
    <div class="controls">
        <input type="text" id="filterDeviceCard" placeholder="Filtrar dispositivo..." onkeyup="loadDevices()">
    </div>
    <div id="devicesGrid" class="card-grid"></div>
</div>

<div id="tab-timeline" class="tab-pane">
    <div class="controls">
        <button onclick="loadTimeline()">Atualizar</button>
    </div>
    <div id="timelineContainer" class="timeline"></div>
</div>

<div id="tab-graph" class="tab-pane">
    <p style="margin-bottom:8px;font-size:13px;color:#666;">Matriz de relacionamento usuário ↔ dispositivo. Células mais escuras = mais conexões.</p>
    <div id="matrixContainer" style="overflow-x:auto;"></div>
</div>


<script>
// -----------------------------------------------------------------------
// Communication via MeshCentral's meshserver (same pattern as EventLog)
// -----------------------------------------------------------------------
var meshserver = (typeof parent !== 'undefined' && parent.meshserver) ? parent.meshserver : (window.meshserver || null);

function sendCmd(pluginaction, extra) {
    if (!meshserver) return;
    extra = extra || {};
    meshserver.send(Object.assign({
        action: 'plugin',
        plugin: 'usertracer',
        pluginaction: pluginaction
    }, extra));
}

// -----------------------------------------------------------------------
// Tab switching
// -----------------------------------------------------------------------
function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });
    var btn = Array.from(document.querySelectorAll('.tab-btn')).find(function(b) { return b.textContent.trim().toLowerCase() === name; }) || document.querySelector('.tab-btn[onclick*="' + name + '"]');
    if (btn) btn.classList.add('active');
    var pane = document.getElementById('tab-' + name);
    if (pane) pane.classList.add('active');
    switch (name) {
        case 'list': loadList(); break;
        case 'users': loadUsers(); break;
        case 'devices': loadDevices(); break;
        case 'timeline': loadTimeline(); break;
        case 'graph': loadGraph(); break;
    }
}

// -----------------------------------------------------------------------
// Tab: List
// -----------------------------------------------------------------------
var _listFilter = {};
function loadList() {
    var tbody = document.getElementById('listBody');
    tbody.innerHTML = '<tr><td colspan="7" class="loading">Carregando...</td></tr>';
    _listFilter = {
        user: (document.getElementById('filterUser').value || '').trim().toLowerCase(),
        device: (document.getElementById('filterDevice').value || '').trim().toLowerCase(),
        type: document.getElementById('filterType').value
    };
    sendCmd('getAllEvents', { limit: 500 });
}

function renderList(data) {
    var tbody = document.getElementById('listBody');
    var f = _listFilter || {};
    if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="loading">Nenhum evento encontrado.</td></tr>';
        return;
    }
    var html = '';
    var labels = { userLogin: 'Login', userLogout: 'Logout', sessionDisconnected: 'Desconectou', sessionReconnected: 'Reconectou' };
    for (var i = 0; i < data.length; i++) {
        var e = data[i];
        if (f.type && e.eventType !== f.type) continue;
        if (f.user && (e.username||'').toLowerCase().indexOf(f.user)===-1) continue;
        if (f.device && (e.nodeName||e.nodeid||'').toLowerCase().indexOf(f.device)===-1) continue;
        var d = new Date(e.detectedAt);
        html += '<tr class="event-' + e.eventType + '">'
            + '<td>' + d.toLocaleDateString() + ' ' + d.toLocaleTimeString() + '</td>'
            + '<td>' + (labels[e.eventType]||e.eventType) + '</td>'
            + '<td>' + (e.username||'') + '</td>'
            + '<td>' + (e.domain||'') + '</td>'
            + '<td>' + (e.nodeName||e.nodeid||'') + '</td>'
            + '<td>' + (e.sessionName||'') + '</td>'
            + '<td>' + (e.state||e.currentState||e.previousState||'') + '</td>'
            + '</tr>';
    }
    tbody.innerHTML = html || '<tr><td colspan="7" class="loading">Nenhum evento corresponde ao filtro.</td></tr>';
}

// -----------------------------------------------------------------------
// Tab: Per-User
// -----------------------------------------------------------------------
function loadUsers() {
    document.getElementById('usersGrid').innerHTML = '<div class="loading">Carregando...</div>';
    sendCmd('getEventsByUser', {});
}

function renderUsers(data) {
    var grid = document.getElementById('usersGrid');
    var filter = (document.getElementById('filterUserCard').value||'').trim().toLowerCase();
    if (!data || !Object.keys(data).length) { grid.innerHTML = '<div class="loading">Nenhum dado.</div>'; return; }
    var keys = Object.keys(data).sort();
    var html = '', count = 0;
    for (var k = 0; k < keys.length; k++) {
        var u = data[keys[k]];
        var label = u.domain ? u.domain + '\\' + u.username : u.username;
        if (filter && label.toLowerCase().indexOf(filter)===-1) continue;
        var deviceHtml = Object.keys(u.devices||{}).sort().map(function(d) {
            return '<span class="device-tag">' + d + ' (' + u.devices[d].count + ')</span>';
        }).join('');
        count++;
        html += '<div class="card"><h3>' + label + '</h3>'
            + '<div class="stat">Eventos: ' + u.totalEvents + ' | Dispositivos: ' + Object.keys(u.devices).length + '</div>'
            + '<div class="stat">Primeiro: ' + (u.firstSeen ? new Date(u.firstSeen).toLocaleString() : '-') + '</div>'
            + '<div class="stat">Último: ' + (u.lastSeen ? new Date(u.lastSeen).toLocaleString() : '-') + '</div>'
            + '<div class="device-list">' + deviceHtml + '</div></div>';
    }
    grid.innerHTML = count ? html : '<div class="loading">Nenhum usuário encontrado.</div>';
}

// -----------------------------------------------------------------------
// Tab: Per-Device
// -----------------------------------------------------------------------
function loadDevices() {
    document.getElementById('devicesGrid').innerHTML = '<div class="loading">Carregando...</div>';
    sendCmd('getEventsByDevice', {});
}

function renderDevices(data) {
    var grid = document.getElementById('devicesGrid');
    var filter = (document.getElementById('filterDeviceCard').value||'').trim().toLowerCase();
    if (!data || !Object.keys(data).length) { grid.innerHTML = '<div class="loading">Nenhum dado.</div>'; return; }
    var keys = Object.keys(data).sort();
    var html = '', count = 0;
    for (var k = 0; k < keys.length; k++) {
        var d = data[keys[k]];
        if (filter && d.nodeName.toLowerCase().indexOf(filter)===-1) continue;
        var userHtml = Object.keys(d.users||{}).sort().map(function(u) {
            return '<span class="device-tag">' + u + ' (' + d.users[u].count + ')</span>';
        }).join('');
        count++;
        html += '<div class="card"><h3>' + d.nodeName + '</h3>'
            + '<div class="stat">Eventos: ' + d.totalEvents + ' | Usuários distintos: ' + Object.keys(d.users).length + '</div>'
            + '<div class="stat">Último evento: ' + (d.lastSeen ? new Date(d.lastSeen).toLocaleString() : '-') + '</div>'
            + '<div class="device-list">' + userHtml + '</div></div>';
    }
    grid.innerHTML = count ? html : '<div class="loading">Nenhum dispositivo encontrado.</div>';
}

// -----------------------------------------------------------------------
// Tab: Timeline
// -----------------------------------------------------------------------
function loadTimeline() {
    document.getElementById('timelineContainer').innerHTML = '<div class="loading">Carregando...</div>';
    sendCmd('getTimeline', { limit: 300 });
}

function renderTimeline(data) {
    var container = document.getElementById('timelineContainer');
    if (!data || !data.length) { container.innerHTML = '<div class="loading">Nenhum evento registrado.</div>'; return; }
    var html = '';
    for (var i = 0; i < data.length; i++) {
        var e = data[i];
        var d = new Date(e.date);
        var cls = 'tl-item';
        if (e.type.indexOf('Login') !== -1) cls += ' login';
        else if (e.type.indexOf('Logout') !== -1) cls += ' logout';
        else if (e.type.indexOf('Disconnect') !== -1) cls += ' disconnect';
        else if (e.type.indexOf('Reconnect') !== -1) cls += ' reconnect';
        html += '<div class="' + cls + '">'
            + '<div class="tl-date">' + d.toLocaleDateString() + ' ' + d.toLocaleTimeString() + '</div>'
            + '<span class="tl-user">' + e.user + '</span> → <span class="tl-device">' + e.device + '</span>'
            + ' <span style="color:#666">(' + e.detail + ')</span>'
            + (e.session ? ' <span style="color:#999;font-size:11px">[' + e.session + ']</span>' : '')
            + '</div>';
    }
    container.innerHTML = html;
}

// -----------------------------------------------------------------------
// Tab: Graph
// -----------------------------------------------------------------------
function loadGraph() {
    sendCmd('getGraphData', {});
}

function renderGraph(data) {
    var container = document.getElementById('matrixContainer');
    if (!data || !data.nodes || !data.nodes.length) {
        container.innerHTML = '<div class="loading">Dados insuficientes para montar a matriz.</div>';
        return;
    }
    // Build user×device matrix from edge list
    var users = [], devices = [], matrix = {}, maxVal = 1;
    data.nodes.forEach(function(n) {
        if (n.type === 'user') users.push(n);
        else devices.push(n);
    });
    data.edges.forEach(function(e) {
        var from = e.from.replace('user_','').replace('device_','');
        var to = e.to.replace('user_','').replace('device_','');
        var uLabel = '', dLabel = '';
        data.nodes.forEach(function(n) {
            if (n.id === e.from) uLabel = n.label;
            if (n.id === e.to) dLabel = n.label;
        });
        var key = uLabel + '|' + dLabel;
        matrix[key] = (matrix[key] || 0) + e.value;
        if (matrix[key] > maxVal) maxVal = matrix[key];
    });
    // Sort
    users.sort(function(a,b){ return a.label.localeCompare(b.label); });
    devices.sort(function(a,b){ return a.label.localeCompare(b.label); });
    // Build HTML table
    var html = '<table style="font-size:11px;border-collapse:collapse;"><thead><tr><th style="padding:4px 8px;background:#f5f5f5;text-align:left;">Usuário \\ Dispositivo</th>';
    devices.forEach(function(d) { html += '<th style="padding:4px 8px;background:#f5f5f5;text-align:center;writing-mode:vertical-lr;height:80px;white-space:nowrap;">' + d.label + '</th>'; });
    html += '</tr></thead><tbody>';
    users.forEach(function(u) {
        html += '<tr><td style="padding:4px 8px;font-weight:600;white-space:nowrap;border-bottom:1px solid #eee;">' + u.label + '</td>';
        devices.forEach(function(d) {
            var key = u.label + '|' + d.label;
            var val = matrix[key] || 0;
            var pct = maxVal > 0 ? val / maxVal : 0;
            var r = Math.round(220 - (pct * 180));
            var g = Math.round(240 - (pct * 180));
            var b = Math.round(220 - (pct * 150));
            var bg = 'rgb(' + r + ',' + g + ',' + b + ')';
            html += '<td style="padding:6px 8px;text-align:center;background:' + bg + ';border-bottom:1px solid #eee;border-right:1px solid #eee;font-size:12px;font-weight:' + (val > 0 ? '600' : '400') + ';">' + (val || '-') + '</td>';
        });
        html += '</tr>';
    });
    html += '</tbody></table>';
    html += '<p style="margin-top:8px;font-size:11px;color:#999;">Células mais escuras = mais eventos de conexão. Clique em "Por Usuário" ou "Por Dispositivo" para detalhes.</p>';
    container.innerHTML = html;
}

// -----------------------------------------------------------------------
// Response handlers — registered on pluginHandler per MeshCentral pattern
// -----------------------------------------------------------------------
function handlePluginMessage(method, data) {
    switch (method) {
        case 'allEvents': renderList(data); break;
        case 'eventsByUser': renderUsers(data); break;
        case 'eventsByDevice': renderDevices(data); break;
        case 'timeline': renderTimeline(data); break;
        case 'graphData': renderGraph(data); break;
    }
}

(function registerHandlers() {
    var target = null;
    try {
        if (typeof pluginHandler !== 'undefined' && pluginHandler.usertracer) {
            target = pluginHandler.usertracer;
        } else if (typeof parent !== 'undefined' && parent.pluginHandler && parent.pluginHandler.usertracer) {
            target = parent.pluginHandler.usertracer;
        }
    } catch(e) {}
    if (!target) { setTimeout(registerHandlers, 500); return; }
    ['allEvents','eventsByUser','eventsByDevice','timeline','graphData','deviceEvents'].forEach(function(m) {
        target[m] = function(msg) {
            handlePluginMessage(m, (msg && msg.data !== undefined) ? msg.data : msg);
        };
    });
})();

// Auto-load on page ready
document.addEventListener('DOMContentLoaded', loadList);
</script>

</body>
</html>
