<html>
<head>
<meta charset="utf-8">
<title>User Tracer</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:"Trebuchet MS",Arial,Helvetica,sans-serif;
  background:#d3d9d6;color:#000;padding:12px;font-size:13px;line-height:1.35;
}
.header{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:10px}
.header h1{font-size:18px;font-weight:700;color:#003366}
.header .sub{color:#444;font-size:12px;margin-top:2px}
.stats{display:flex;gap:6px;flex-wrap:wrap}
.stat{background:#fff;border:1px solid #aaa;border-radius:3px;padding:8px 12px;min-width:88px}
.stat .n{font-size:18px;font-weight:700;color:#003366}
.stat .l{font-size:10px;color:#666;text-transform:uppercase;margin-top:1px}
.panel{background:#fff;border:1px solid #aaa;border-radius:3px;padding:10px;margin-bottom:10px}
.panel-title{
  background:#c0c0c0;color:#000;font-size:12px;font-weight:700;
  padding:5px 8px;margin:-10px -10px 10px -10px;border-bottom:1px solid #aaa;
}
.toolbar{display:flex;flex-wrap:wrap;gap:6px;align-items:center;margin-bottom:8px}
.toolbar label{font-size:11px;color:#444;font-weight:700}
.toolbar select{
  font-family:inherit;font-size:12px;border:1px solid #808080;background:#fff;
  color:#000;padding:4px 6px;border-radius:2px;
}
.btn{
  font-family:inherit;font-size:12px;border:1px solid #808080;background:#f0f0f0;
  color:#000;padding:5px 12px;border-radius:2px;cursor:pointer;
}
.btn:hover{background:#e4e4e4}
.btn-primary{background:#003366;color:#fff;border-color:#002244}
.btn-primary:hover{background:#004080}
.loading{text-align:center;padding:28px;color:#666}
.muted{color:#666;font-size:11px}
.empty{text-align:center;padding:36px 16px;color:#666;background:#fff}
.xref-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.xref-grid .col{min-width:0}
@media(max-width:768px){.xref-grid{grid-template-columns:1fr}}
.stacked{display:flex;gap:8px;flex-direction:column;max-height:320px;overflow-y:auto;padding-right:4px}
.stacked .scard{
  display:flex;gap:8px;align-items:center;padding:8px 10px;
  background:#f7f8f7;border:1px solid #ddd;border-radius:2px;
}
.stacked .scard:hover{border-color:#003366;background:#eef3f8}
.scard .tag{font-weight:700;color:#003366;font-size:12px;flex:1}
.scard .tagl{color:#555;font-size:11px}
.scard .badge{font-size:10px;color:#666;background:#eee;padding:2px 6px;border-radius:999px}
#dbgToggle{cursor:pointer;font-size:11px;color:#003366;user-select:none;margin-top:10px;text-decoration:underline}
#debug{
  display:none;background:#fff8e1;border:1px solid #e0c060;color:#333;
  padding:6px;margin-top:4px;font-size:10px;font-family:Consolas,monospace;
  max-height:140px;overflow:auto;border-radius:2px;white-space:pre-wrap;
}
</style>
</head>
<body>
<div class="header">
  <div>
    <h1>User Tracer</h1>
    <div class="sub">Lastro AD · cruzamento usuários × dispositivos · auditoria</div>
  </div>
  <div class="stats">
    <div class="stat"><div class="n" id="sDevices">—</div><div class="l">Dispositivos</div></div>
    <div class="stat"><div class="n" id="sUsers">—</div><div class="l">Usuários</div></div>
    <div class="stat"><div class="n" id="sEvents">—</div><div class="l">Eventos</div></div>
  </div>
</div>

<div class="xref-grid">
  <div class="col">
    <div class="panel">
      <div class="panel-title">Usuário → Dispositivos</div>
      <div class="toolbar">
        <select id="xrefUser" style="flex:1" onchange="loadXrefUser()">
          <option value="">— Selecione um usuário —</option>
        </select>
        <button class="btn btn-primary" onclick="loadXrefUser()">Buscar</button>
        <span class="muted" id="hintUser"></span>
      </div>
      <div id="xrefUserResult"><div class="empty">Selecione um usuário para ver em quais dispositivos ele já logou.</div></div>
    </div>
  </div>
  <div class="col">
    <div class="panel">
      <div class="panel-title">Dispositivo → Usuários</div>
      <div class="toolbar">
        <select id="xrefDev" style="flex:1" onchange="loadXrefDev()">
          <option value="">— Selecione um dispositivo —</option>
        </select>
        <button class="btn btn-primary" onclick="loadXrefDev()">Buscar</button>
        <span class="muted" id="hintDev"></span>
      </div>
      <div id="xrefDevResult"><div class="empty">Selecione um dispositivo para ver quais usuários já logaram nele.</div></div>
    </div>
  </div>
</div>

<div id="dbgToggle" onclick="var e=document.getElementById('debug');e.style.display=e.style.display==='none'?'block':'none'">Debug</div>
<div id="debug">aguardando...</div>

<script>
var D=[], ms=(typeof parent!=='undefined'&&parent.meshserver)||window.meshserver;
var _allDevices=[], _allUsers=[], _xrefPending='';
function esc(s){return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function dlog(){var a=Array.prototype.slice.call(arguments);D.push(new Date().toLocaleTimeString()+' '+a.join(' '));var e=document.getElementById('debug');if(e)e.innerHTML=D.slice(-80).join('\n');}
function splitUser(u){var p=String(u||'').split('\\');return p.length>1?{domain:p[0],user:p[1]}:{domain:'',user:u||''};}
function fmtDate(d){var x=new Date(d);if(isNaN(x))return'—';var m=x.getMonth()+1,day=x.getDate();return (day<10?'0':'')+day+'/'+(m<10?'0':'')+m+' '+x.getHours()+':'+(x.getMinutes()<10?'0':'')+x.getMinutes();}

/* ===== LOAD DATA ===== */
function loadAll(){
  document.getElementById('sDevices').textContent='…';
  if(ms){
    ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getDeviceNames'});
    ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getUserNames'});
  }
}
function renderDeviceNames(list){
  _allDevices=(list||[]).slice().sort(function(a,b){return String(a.name).localeCompare(String(b.name));});
  document.getElementById('sDevices').textContent=_allDevices.length;
  var devSel=document.getElementById('xrefDev');
  devSel.innerHTML='<option value="">— Selecione um dispositivo —</option>';
  _allDevices.forEach(function(d){
    var opt=document.createElement('option');
    opt.value=d.nodeid; opt.textContent=d.name; devSel.appendChild(opt);
  });
}
function renderUserNames(list){
  _allUsers=(list||[]).slice().sort(function(a,b){return String(a.displayUser||a.username).localeCompare(String(b.displayUser||b.username));});
  document.getElementById('sUsers').textContent=_allUsers.length;
  var sel=document.getElementById('xrefUser');
  sel.innerHTML='<option value="">— Selecione um usuário —</option>';
  _allUsers.forEach(function(u){
    var opt=document.createElement('option');
    opt.value=(u.username||u.displayUser);
    opt.textContent=(u.displayUser||u.username);
    sel.appendChild(opt);
  });
}

/* ===== CROSS-REFERENCE ===== */
function loadXrefUser(){
  var uname=document.getElementById('xrefUser').value;
  if(!uname){document.getElementById('xrefUserResult').innerHTML='<div class="empty">Selecione um usuário.</div>';return;}
  document.getElementById('xrefUserResult').innerHTML='<div class="loading">Buscando...</div>';
  document.getElementById('hintUser').textContent='';
  _xrefPending='user'; if(ms)ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getTimeline',username:uname,limit:5000});
}
function loadXrefDev(){
  var nid=document.getElementById('xrefDev').value;
  if(!nid){document.getElementById('xrefDevResult').innerHTML='<div class="empty">Selecione um dispositivo.</div>';return;}
  document.getElementById('xrefDevResult').innerHTML='<div class="loading">Buscando...</div>';
  document.getElementById('hintDev').textContent='';
  _xrefPending='dev'; if(ms)ms.send({action:'plugin',plugin:'usertracer',pluginaction:'getTimeline',nodeid:nid,limit:5000});
}
function renderXrefUser(events){
  events=events||[];
  document.getElementById('sEvents').textContent=events.length;
  if(!events.length){document.getElementById('xrefUserResult').innerHTML='<div class="empty">Nenhum evento encontrado para este usuário.</div>';return;}
  var byDev={};
  events.forEach(function(e){
    var n=e.nodeName||e.nodeid||'?';
    if(!byDev[n]){byDev[n]={name:n,events:[]};}
    byDev[n].events.push(e);
  });
  var names=Object.keys(byDev).sort();
  document.getElementById('hintUser').textContent=events.length+' eventos em '+names.length+' dispositivos';
  var h='<div class="stacked">';
  names.forEach(function(name){
    var evs=byDev[name].events.sort(function(a,b){return new Date(b.detectedAt)-new Date(a.detectedAt);});
    var last=evs[0], first=evs[evs.length-1];
    h+='<div class="scard">'
      +'<div style="flex:1"><div class="tag">'+esc(name)+'</div>'
      +'<div class="tagl">'+evs.length+' eventos · '+fmtDate(first.detectedAt)+' → '+fmtDate(last.detectedAt)+'</div></div>'
      +'<span class="badge" style="color:'+(last.eventType==='userLogin'?'#2e7d32':'#888')+'">'+(last.eventType==='userLogin'?'Online':'Offline')+'</span>'
      +'</div>';
  });
  h+='</div>';
  document.getElementById('xrefUserResult').innerHTML=h;
}
function renderXrefDev(events){
  events=events||[];
  document.getElementById('sEvents').textContent=events.length;
  if(!events.length){document.getElementById('xrefDevResult').innerHTML='<div class="empty">Nenhum evento encontrado para este dispositivo.</div>';return;}
  var byUser={};
  events.forEach(function(e){
    var u=e.displayUser||e.username||'?';
    if(!byUser[u]){byUser[u]={user:u,domain:e.domain,events:[]};}
    byUser[u].events.push(e);
  });
  var usernames=Object.keys(byUser).sort();
  document.getElementById('hintDev').textContent=events.length+' eventos de '+usernames.length+' usuários';
  var h='<div class="stacked">';
  usernames.forEach(function(u){
    var g=byUser[u], evs=g.events.sort(function(a,b){return new Date(b.detectedAt)-new Date(a.detectedAt);});
    var last=evs[0], first=evs[evs.length-1];
    var un=splitUser(g.user);
    h+='<div class="scard">'
      +'<div style="flex:1"><div class="tag">'+esc(un.user||g.user)+'</div>'
      +'<div class="tagl">'+(g.domain?esc(g.domain)+' · ':'')+evs.length+' eventos · '+fmtDate(first.detectedAt)+' → '+fmtDate(last.detectedAt)+'</div></div>'
      +'<span class="badge" style="color:'+(last.eventType==='userLogin'?'#2e7d32':'#888')+'">'+(last.eventType==='userLogin'?'Online':'Offline')+'</span>'
      +'</div>';
  });
  h+='</div>';
  document.getElementById('xrefDevResult').innerHTML=h;
}

/* ===== WS ===== */
if(ms&&ms.socket){
  var orig=ms.socket.onmessage;
  ms.socket.onmessage=function(event){
    try{
      var d=JSON.parse(event.data);
      if(d.action==='plugin'&&d.plugin==='usertracer'){
        dlog('WS', d.method, Array.isArray(d.data)?('n='+d.data.length):typeof d.data);
        if(d.method==='deviceNames')renderDeviceNames(d.data||[]);
        else if(d.method==='userNames')renderUserNames(d.data||[]);
        else if(d.method==='timeline'){
          if(_xrefPending==='user'){renderXrefUser(d.data||[]);_xrefPending='';}
          else if(_xrefPending==='dev'){renderXrefDev(d.data||[]);_xrefPending='';}
        }
        return;
      }
    }catch(e){}
    if(typeof orig==='function')orig.call(ms.socket,event);
  };
  dlog('socket hooked');
}

document.addEventListener('DOMContentLoaded',function(){loadAll();});
</script>
</body>
</html>
